{
  "name": "vite-vue-ts-starter",
  "type": "module",
  "version": "0.1.0",
  "author": "zhixiangyao <blueskyzx@icloud.com> <https://github.com/zhixiangyao>",
  "license": "MIT",
  "homepage": "https://github.com/zhixiangyao/vite-vue-ts-starter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhixiangyao/vite-vue-ts-starter.git"
  },
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=10.33.2"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "pnpm typecheck && vite build",
    "preview": "npm run build && vite preview",
    "preview:dist": "vite preview",
    "typecheck": "vue-tsc -b",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "lint:css": "stylelint \"./**/*.{vue,css}\" --cache --cache-location node_modules/.cache/stylelint/",
    "lint-staged": "lint-staged",
    "postinstall": "simple-git-hooks"
  },
  "dependencies": {
    "nprogress": "0.2.0",
    "pinia": "3.0.4",
    "vue": "3.5.33",
    "vue-router": "5.0.6"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "@types/nprogress": "0.2.3",
    "@vitejs/plugin-vue": "6.0.6",
    "@vitejs/plugin-vue-jsx": "5.1.5",
    "@vue/compiler-sfc": "3.5.33",
    "@vue/tsconfig": "0.9.1",
    "lint-staged": "16.4.0",
    "oxfmt": "0.46.0",
    "oxlint": "1.62.0",
    "postcss-html": "1.8.1",
    "postcss-load-config": "6.0.1",
    "simple-git-hooks": "2.13.1",
    "stylelint": "17.9.0",
    "stylelint-config-recess-order": "7.7.0",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "8.1.1",
    "tailwindcss": "3.4.18",
    "typescript": "6.0.3",
    "unplugin-auto-import": "21.0.0",
    "unplugin-vue-components": "32.0.0",
    "vite": "8.0.10",
    "vue-tsc": "3.2.7"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "**/*.{js,cjs,mjs,jsx,ts,mts,tsx,vue}": [
      "pnpm lint:check"
    ],
    "**/*.{js,cjs,mjs,jsx,ts,mts,tsx,vue,html,md,json,css,yaml,yml}": [
      "pnpm fmt:check"
    ],
    "**/*.{vue,css}": [
      "stylelint --cache --cache-location node_modules/.cache/stylelint/"
    ]
  }
}
